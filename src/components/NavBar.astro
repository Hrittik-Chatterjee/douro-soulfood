---
/**
 * NavBar — Sticky glassmorphic navigation with mobile menu.
 *
 * Features:
 * - Scroll-activated glass effect (adds .glass class on scroll)
 * - Desktop nav links + Reservierung outlined + Order CTA (brand gold glow)
 * - Mobile hamburger + slide-in overlay
 * - Slot composition: <slot /> for additional nav items
 *
 * Tokens: brand-gold, surface-glass, text-primary/secondary/tertiary, border-subtle/default.
 * Zero hex codes. All colors from tokens.css @theme.
 */

interface NavLink {
  label: string;
  href: string;
}

interface Props {
  /** Navigation links — rendered in desktop nav and mobile overlay */
  links?: NavLink[];
  /** Brand name displayed in display font */
  brandName?: string;
  /** Brand subtitle (hidden on small screens) */
  brandSubtitle?: string;
  /** Primary CTA button config (gold with glow) */
  ctaPrimary?: { label: string; href: string };
  /** Secondary outlined button config */
  ctaSecondary?: { label: string; href: string };
  /** Additional CSS classes */
  class?: string;
}

const {
  links = [
    { label: 'Speisekarte', href: '/menu' },
    { label: 'Catering', href: '/catering' },
    { label: 'Über uns', href: '/about' },
    { label: 'Kontakt', href: '/contact' },
  ],
  brandName = "D'ouro",
  brandSubtitle = 'Soulfood',
  ctaPrimary = { label: 'Jetzt bestellen', href: '/menu' },
  ctaSecondary = { label: 'Reservierung', href: '/contact' },
  class: className = '',
} = Astro.props;
---

<nav
  aria-label="Hauptmenü"
  class:list={[
    'sticky top-0 z-50 bg-surface-glass backdrop-blur-sm transition-all duration-[var(--duration-fast)] ease-[var(--ease-spring)] border-b border-border-subtle',
    className,
  ]}
  data-nav
>
  <div class="mx-auto flex max-w-7xl items-center px-4 py-4 md:px-16 gap-2">

    <!-- Logo — Brand name in display font -->
    <div class="md:shrink-0">
      <a href="/" class="flex items-center gap-1 no-underline hover:no-underline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-gold rounded-xs">
        <span class="text-xl font-bold text-brand-gold font-display">{brandName}</span>
        <span class="text-sm text-text-secondary hidden sm:inline">{brandSubtitle}</span>
      </a>
    </div>

    <!-- Desktop Navigation Links -->
    <div class="hidden flex-1 justify-end items-center min-w-0 md:flex">
      <div class="relative w-full max-w-full">
        <div class="flex items-center justify-end gap-2 p-2">
          <!-- Nav links — secondary text, hover gold -->
          <div class="flex gap-2 items-center min-w-0">
            <div class="flex gap-2 items-center">
              {links.map((link) => (
                <a
                  href={link.href}
                  class="flex min-h-11 items-center px-4 py-2 text-base font-bold tracking-wider uppercase whitespace-nowrap
                         text-text-secondary rounded-sm hover:bg-surface-elevated hover:text-text-primary
                         focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-gold
                         no-underline transition-all duration-[var(--duration-fast)] ease-[var(--ease-spring)]"
                >
                  {link.label}
                </a>
              ))}
            </div>
          </div>

          <!-- Fixed right items -->
          <div class="flex gap-2 items-center shrink-0">
            {/* Reservierung — secondary outlined */}
            {ctaSecondary && (
              <a
                href={ctaSecondary.href}
                class="flex min-h-11 items-center px-4 py-2 text-base font-bold tracking-wider uppercase rounded-sm
                       border border-border-default bg-surface-elevated
                       hover:bg-surface-card hover:border-border-emphasis hover:text-text-primary
                       focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-gold
                       active:bg-surface-primary
                       text-text-secondary no-underline transition-all duration-[var(--duration-fast)] ease-[var(--ease-spring)]"
              >
                {ctaSecondary.label}
              </a>
            )}

            {/* Order CTA — brand gold with glow */}
            {ctaPrimary && (
              <a
                href={ctaPrimary.href}
                class="group flex min-h-11 items-center px-5 py-2 text-base font-bold tracking-wider uppercase rounded-sm
                       bg-brand-gold hover:bg-brand-gold-light active:bg-brand-gold-dark text-brand-espresso
                       focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-gold
                       no-underline transition-all duration-[var(--duration-fast)] ease-[var(--ease-spring)] shadow-glow-gold"
              >
                <span class="flex items-center gap-1 whitespace-nowrap">{ctaPrimary.label}</span>
                <svg
                  class="ml-1 w-4 h-4 opacity-50 group-hover:opacity-100 group-hover:translate-x-0.5 transition-all duration-[var(--duration-fast)] ease-[var(--ease-spring)]"
                  viewBox="0 0 256 256" fill="none" stroke="currentColor"
                  stroke-width="24" stroke-linecap="round" stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <polyline points="96 48 176 128 96 208" />
                </svg>
              </a>
            )}
          </div>
        </div>
      </div>
    </div>

    <!-- Mobile Menu Button -->
    <div class="flex flex-1 justify-end items-center md:hidden">
      <div class="flex shrink-0 items-center gap-2 p-1 rounded-sm border border-transparent bg-surface-primary">
        {ctaPrimary && (
          <a
            href={ctaPrimary.href}
            class="flex min-h-11 items-center px-3 py-2 text-sm font-medium rounded-sm
                   border border-border-default bg-surface-elevated
                   hover:bg-surface-card hover:border-border-emphasis hover:text-text-primary
                   active:bg-surface-primary
                   text-text-secondary no-underline transition-colors duration-[var(--duration-fast)] ease-[var(--ease-spring)]"
          >
            Speisekarte
          </a>
        )}
        <button
          id="mobile-menu-btn"
          type="button"
          class="flex justify-center items-center w-11 h-11 rounded-sm
                 hover:bg-surface-elevated focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-gold
                 transition-colors duration-[var(--duration-fast)] ease-[var(--ease-spring)]"
          aria-label="Navigationsmenü öffnen"
          aria-expanded="false"
        >
          <div class="flex flex-col gap-1.5 justify-center items-center w-6 h-6">
            <span class="block h-0.5 w-6 bg-text-primary rounded-full transition-transform duration-[var(--duration-fast)] ease-[var(--ease-out-quint)]" data-line-top></span>
            <span class="block h-0.5 w-6 bg-text-primary rounded-full transition-opacity duration-[var(--duration-fast)] ease-[var(--ease-out-quint)]" data-line-mid></span>
            <span class="block h-0.5 w-6 bg-text-primary rounded-full transition-transform duration-[var(--duration-fast)] ease-[var(--ease-out-quint)]" data-line-bot></span>
          </div>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu Overlay -->
  <div
    id="mobile-menu"
    class="fixed top-20 right-0 bottom-0 left-0 z-40 bg-surface-primary
           opacity-0 pointer-events-none transition-opacity duration-[var(--duration-normal)] ease-[var(--ease-out-quint)]
           md:hidden overflow-y-auto"
    role="dialog"
    aria-modal="true"
    aria-label="Navigationsmenü"
    data-open="false"
  >
    <div class="mx-auto max-w-7xl px-4 py-6">
      <nav aria-label="Mobile Navigation" class="flex flex-col gap-2">
        {ctaSecondary && (
          <a
            href={ctaSecondary.href}
            class="flex min-h-12 items-center px-4 py-3 text-lg font-bold tracking-wider uppercase
                   text-text-secondary rounded-sm hover:bg-surface-elevated hover:text-text-primary
                   focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-gold
                   active:bg-surface-card
                   no-underline transition-colors duration-[var(--duration-fast)] ease-[var(--ease-spring)]"
          >
            {ctaSecondary.label}
          </a>
        )}
        {links.map((link) => (
          <a
            href={link.href}
            class="flex min-h-12 items-center px-4 py-3 text-lg font-bold tracking-wider uppercase
                   text-text-secondary rounded-sm hover:bg-surface-elevated hover:text-text-primary
                   focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-gold
                   active:bg-surface-card
                   no-underline transition-colors duration-[var(--duration-fast)] ease-[var(--ease-spring)]"
          >
            {link.label}
          </a>
        ))}
        {ctaPrimary && (
          <a
            href={ctaPrimary.href}
            class="mt-4 flex items-center justify-center min-h-12 rounded-sm
                   bg-brand-gold hover:bg-brand-gold-light active:bg-brand-gold-dark
                   px-5 py-3 text-lg font-bold tracking-wider uppercase
                   text-brand-espresso no-underline transition-colors duration-[var(--duration-fast)] ease-[var(--ease-spring)]
                   shadow-glow-gold focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-gold"
          >
            {ctaPrimary.label}
          </a>
        )}
      </nav>
    </div>
  </div>
</nav>

<!-- Slot for additional nav-related content -->
<slot />

<script>
  // Glass effect on scroll — adds .glass class when page is scrolled
  const nav = document.querySelector('[data-nav]') as HTMLElement;
  if (nav) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (!entry.isIntersecting) {
          nav.classList.add('glass');
        } else {
          nav.classList.remove('glass');
        }
      },
      { threshold: 1, rootMargin: '-1px 0px 0px 0px' }
    );
    const sentinel = document.createElement('div');
    sentinel.style.height = '1px';
    document.body.prepend(sentinel);
    observer.observe(sentinel);
  }

  // Mobile menu toggle
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');

  function closeMenu() {
    if (menu) {
      menu.dataset.open = 'false';
      menu.classList.add('opacity-0');
      menu.classList.add('pointer-events-none');
    }
    btn?.setAttribute('aria-expanded', 'false');

    // Reset hamburger lines
    const topLine = btn?.querySelector('[data-line-top]');
    const midLine = btn?.querySelector('[data-line-mid]');
    const botLine = btn?.querySelector('[data-line-bot]');

    topLine?.classList.remove('rotate-45', 'translate-y-2');
    midLine?.classList.remove('opacity-0');
    botLine?.classList.remove('-rotate-45', '-translate-y-2');
  }

  btn?.addEventListener('click', () => {
    const isOpen = menu?.dataset.open === 'true';

    if (menu) {
      menu.dataset.open = String(!isOpen);
      menu.classList.toggle('opacity-0', isOpen);
      menu.classList.toggle('pointer-events-none', isOpen);
    }

    btn.setAttribute('aria-expanded', String(!isOpen));

    // Animate hamburger lines
    const topLine = btn.querySelector('[data-line-top]');
    const midLine = btn.querySelector('[data-line-mid]');
    const botLine = btn.querySelector('[data-line-bot]');

    if (!isOpen) {
      topLine?.classList.add('rotate-45', 'translate-y-2');
      midLine?.classList.add('opacity-0');
      botLine?.classList.add('-rotate-45', '-translate-y-2');
    } else {
      topLine?.classList.remove('rotate-45', 'translate-y-2');
      midLine?.classList.remove('opacity-0');
      botLine?.classList.remove('-rotate-45', '-translate-y-2');
    }
  });

  // Close mobile menu on Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && menu?.dataset.open === 'true') {
      closeMenu();
      btn?.focus();
    }
  });
</script>
