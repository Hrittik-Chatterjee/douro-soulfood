---
import { Image } from 'astro:assets';
import DietaryBadge from './DietaryBadge.astro';

/**
 * MenuItemCard — Glassmorphic card for a single menu item.
 *
 * Displays: image (optional), name, description, price in EUR,
 * dietary badges, and availability indicator.
 *
 * Tokens: brand-gold, surface-glass/card, text-primary/secondary, border-subtle.
 * Zero hex codes. All colors from tokens.css @theme.
 */

type DietaryTag = 'vegan' | 'vegetarian' | 'gluten-free' | 'spicy' | 'halal' | 'dairy-free';

interface Props {
  /** Dish name */
  name: string;
  /** Short description */
  description: string;
  /** Price in EUR cents (e.g. 1490 = €14.90) */
  priceInCents: number;
  /** Dietary tags */
  dietary?: DietaryTag[];
  /** Is this item currently available? */
  available?: boolean;
  /** Is this item featured? */
  featured?: boolean;
  /** Optional dish image URL (remote or local path) */
  imageSrc?: string;
  /** Alt text for the image */
  imageAlt?: string;
  /** Image width */
  imageWidth?: number;
  /** Image height */
  imageHeight?: number;
  /** Additional CSS classes */
  class?: string;
}

const {
  name,
  description,
  priceInCents,
  dietary = [],
  available = true,
  featured = false,
  imageSrc,
  imageAlt = '',
  imageWidth = 400,
  imageHeight = 300,
  class: className = '',
} = Astro.props;

/** Format price from cents to EUR display string */
const formatPrice = (cents: number): string => {
  const euros = cents / 100;
  return new Intl.NumberFormat('de-AT', {
    style: 'currency',
    currency: 'EUR',
    minimumFractionDigits: 2,
  }).format(euros);
};
---

<article
  class:list={[
    'group relative flex flex-col rounded-lg overflow-hidden',
    'bg-surface-glass backdrop-blur-sm border border-border-subtle',
    'transition-all duration-[var(--duration-fast)] ease-[var(--ease-spring)] hover:border-border-default hover:shadow-md',
    !available && 'opacity-60',
    className,
  ]}
>
  {/* Featured indicator */}
  {featured && (
    <div class="absolute top-3 right-3 z-10">
      <span class="inline-flex items-center gap-1 px-2 py-0.5 text-xs font-semibold rounded-xs bg-brand-gold/20 text-brand-gold border border-brand-gold/30">
        <svg class="w-3 h-3" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
        </svg>
        Empfehlung
      </span>
    </div>
  )}

  {/* Image — optional, glassmorphic placeholder if missing */}
  {imageSrc ? (
    <div class="relative aspect-[4/3] overflow-hidden bg-surface-card">
      <Image
        src={imageSrc}
        alt={imageAlt || name}
        width={imageWidth}
        height={imageHeight}
        format="webp"
        quality={85}
        class="w-full h-full object-cover transition-transform duration-[var(--duration-normal)] ease-[var(--ease-out-quart)] group-hover:scale-105"
        loading="lazy"
      />
      {!available && (
        <div class="absolute inset-0 bg-surface-primary/70 flex items-center justify-center">
          <span class="text-sm font-semibold text-text-tertiary uppercase tracking-wider">Nicht verfügbar</span>
        </div>
      )}
    </div>
  ) : (
    <div class="relative aspect-[4/3] bg-surface-card flex items-center justify-center">
      <svg class="w-12 h-12 text-text-tertiary/30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" />
      </svg>
    </div>
  )}

  {/* Content */}
  <div class="flex flex-col flex-1 p-4 gap-2">
    {/* Name + Price */}
    <div class="flex items-start justify-between gap-2">
      <h3 class="text-base font-semibold text-text-primary font-display leading-tight">
        {name}
      </h3>
      <span class="shrink-0 text-base font-bold text-brand-gold whitespace-nowrap">
        {formatPrice(priceInCents)}
      </span>
    </div>

    {/* Description */}
    <p class="text-sm text-text-secondary leading-relaxed line-clamp-3 max-w-[75ch]">
      {description}
    </p>

    {/* Dietary badges */}
    {dietary.length > 0 && (
      <div class="flex flex-wrap gap-1.5 mt-1">
        {dietary.map((tag) => (
          <DietaryBadge tag={tag} />
        ))}
      </div>
    )}
  </div>
</article>
