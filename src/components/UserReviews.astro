---
/**
 * UserReviews — Premium testimonial section displaying guest reviews.
 * Displays: 5-star ratings, testimonial text, reviewer names, avatars (initials), and review source.
 * Styled using the project's glassmorphism and gold branding tokens.
 */

interface Review {
  name: string;
  source: string;
  rating: number;
  text: string;
}

interface Props {
  /** Section title */
  title?: string;
  /** Section subtitle */
  subtitle?: string;
  /** Custom list of reviews */
  reviews?: Review[];
}

const {
  title = "Was unsere Gäste sagen",
  subtitle = "Echtes Feedback von unseren Gästen in Salzburg.",
  reviews = [
    {
      name: 'Lukas M.',
      source: 'Google Review',
      rating: 5,
      text: 'Das beste Afro-Latin Food in Salzburg! Die Beef Tacos und die Caipirinha sind einfach weltklasse. Super Atmosphäre und Angela ist extrem herzlich.',
    },
    {
      name: 'Amara K.',
      source: 'TripAdvisor',
      rating: 5,
      text: "Angela's food is full of flavor and cooked with love. The Fufu and Egusi soup took me right back to West Africa. An absolute gem in the city!",
    },
    {
      name: 'Sophie B.',
      source: 'Google Review',
      rating: 5,
      text: 'Wir haben das Catering für eine Firmenfeier gebucht und alle waren restlos begeistert. Unglaublich leckeres Essen, frische Zutaten und toller Service!',
    }
  ],
} = Astro.props;

// Helper to get initials for avatar
const getInitials = (name: string) => {
  return name
    .split(' ')
    .map((n) => n[0])
    .join('')
    .toUpperCase();
};
---

<section class="max-w-7xl mx-auto py-16 md:py-24 px-4 md:px-16" aria-label="Gästebewertungen">
  <div class="text-center mb-10 md:mb-14">
    <span class="inline-block text-sm font-semibold text-brand-gold uppercase tracking-wider mb-2">
      Bewertungen
    </span>
    <h2 class="text-2xl md:text-4xl font-semibold text-text-primary font-display">
      {title}
    </h2>
    <p class="text-text-secondary mt-3 max-w-[75ch] mx-auto">
      {subtitle}
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
    {reviews.map((review) => (
      <div class="flex flex-col justify-between rounded-xl bg-surface-glass backdrop-blur-sm border border-border-subtle p-6 md:p-8 transition-all duration-[var(--duration-fast)] ease-[var(--ease-spring)] hover:border-border-default hover:shadow-md">
        <div class="flex flex-col gap-4">
          {/* Star rating */}
          <div class="flex items-center gap-0.5 text-brand-gold" role="img" aria-label={`${review.rating} Sterne`}>
            {Array.from({ length: review.rating }).map(() => (
              <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>

          {/* Testimonial text */}
          <p class="text-text-secondary italic leading-relaxed text-sm md:text-base">
            "{review.text}"
          </p>
        </div>

        {/* Reviewer Details */}
        <div class="flex items-center gap-3 mt-6 pt-4 border-t border-border-subtle/50">
          <div class="w-10 h-10 rounded-full bg-brand-gold/10 text-brand-gold font-bold flex items-center justify-center text-sm shrink-0 border border-brand-gold/20 select-none">
            {getInitials(review.name)}
          </div>
          <div class="flex flex-col min-w-0">
            <span class="text-sm font-semibold text-text-primary truncate">{review.name}</span>
            <span class="text-xs text-text-tertiary truncate">{review.source}</span>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>
