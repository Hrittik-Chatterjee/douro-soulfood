---
/**
 * DietaryBadge — Colored badge for dietary flags (vegan, spicy, etc.)
 *
 * Each flag gets a distinct color:
 *   vegan       → brand-forest (green)
 *   vegetarian  → brand-sage (muted green)
 *   gluten-free → brand-gold (gold)
 *   spicy       → brand-terracotta (red/warm)
 *   halal       → brand-cream (cream)
 *   dairy-free  → brand-forest-light
 *
 * Tokens: brand-*, surface-card, text-*, border-subtle.
 * Zero hex codes. All colors from tokens.css @theme.
 */

type DietaryTag = 'vegan' | 'vegetarian' | 'gluten-free' | 'spicy' | 'halal' | 'dairy-free';

interface Props {
  /** The dietary tag to display */
  tag: DietaryTag;
  /** Additional CSS classes */
  class?: string;
}

const { tag, class: className = '' } = Astro.props;

const tagConfig: Record<DietaryTag, { label: string; description: string; classes: string }> = {
  vegan: {
    label: 'Vegan',
    description: 'Keine tierischen Produkte',
    classes: 'bg-brand-forest/20 text-brand-forest-light border-brand-forest/30',
  },
  vegetarian: {
    label: 'Vegetarisch',
    description: 'Ohne Fleisch',
    classes: 'bg-brand-sage/20 text-brand-sage border-brand-sage/30',
  },
  'gluten-free': {
    label: 'Glutenfrei',
    description: 'Ohne Gluten',
    classes: 'bg-brand-gold/15 text-brand-gold border-brand-gold/25',
  },
  spicy: {
    label: 'Scharf',
    description: 'Mit Schärfe',
    classes: 'bg-brand-forest/20 text-brand-forest-light border-brand-forest/30',
  },
  halal: {
    label: 'Halal',
    description: 'Halal-zertifiziert',
    classes: 'bg-brand-cream/15 text-brand-cream-warm border-brand-cream/25',
  },
  'dairy-free': {
    label: 'Laktosefrei',
    description: 'Ohne Milchprodukte',
    classes: 'bg-brand-forest-light/15 text-brand-forest-light border-brand-forest-light/25',
  },
};

const config = tagConfig[tag];
---

<span
  class:list={[
    'inline-flex items-center gap-1 px-2 py-0.5 text-xs font-medium rounded-xs border',
    config.classes,
    className,
  ]}
  title={config.description}
>
  {tag === 'spicy' && (
    <svg class="w-3 h-3" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
      <path d="M10 2C10 2 6 5 6 9c0 2 1 3.5 2.5 4.5C7 14 6 15 6 16h8c0-1-1-2-2.5-2.5C13 12.5 14 11 14 9c0-4-4-7-4-7z" />
    </svg>
  )}
  {config.label}
</span>
