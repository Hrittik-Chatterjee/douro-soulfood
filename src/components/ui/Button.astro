---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  arrow?: boolean;
  class?: string;
}

const {
  href,
  variant = 'primary',
  size = 'md',
  arrow = false,
  class: className = '',
} = Astro.props;

const baseClasses = `group relative inline-flex items-center justify-center font-semibold
  rounded-[var(--radius-sm)] transition-all duration-[var(--duration-fast)] ease-[var(--ease-spring)]
  focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-brand-gold)]`;

const variants = {
  primary: `bg-brand-gold text-brand-espresso
    hover:bg-brand-gold-light hover:shadow-glow-gold
    active:bg-brand-gold-dark`,
  secondary: `border border-border-default text-text-secondary
    hover:bg-surface-elevated hover:text-text-primary hover:border-border-emphasis
    active:bg-surface-primary`,
  ghost: `text-text-secondary hover:text-text-primary
    hover:bg-surface-elevated active:bg-surface-primary`,
};

const sizes = {
  sm: 'min-h-9 px-3 py-2 text-sm gap-1.5',
  md: 'min-h-11 px-5 py-2.5 text-sm gap-2',
  lg: 'min-h-12 px-6 py-3 text-base gap-2',
};

const classes = `${baseClasses} ${variants[variant]} ${sizes[size]} ${className}`;

const Tag = href ? 'a' : 'button';
---

<Tag href={href} class={classes}>
  <slot />
  {arrow && (
    <svg
      class="w-4 h-4 transition-transform duration-[var(--duration-fast)] ease-[var(--ease-spring)]
             group-hover:translate-x-0.5 opacity-60 group-hover:opacity-100"
      viewBox="0 0 20 20" fill="none" stroke="currentColor"
      stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M7.5 5L12.5 10L7.5 15" />
    </svg>
  )}
</Tag>
